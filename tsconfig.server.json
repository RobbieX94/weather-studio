{
  "compilerOptions": {
    "target": "es2023",
    "lib": ["ES2023"],
    "module": "commonjs",
    "moduleResolution": "node",
    "ignoreDeprecations": "6.0",
    "types": ["node"],
    "skipLibCheck": true,
    "esModuleInterop": true,
    "noEmit": true,
    "outDir": "./dist/server",
    "baseUrl": "."
  },
  "include": ["server/**/*", "src/generated/prisma/**/*"]
}
